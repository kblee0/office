<customUI xmlns="http://schemas.microsoft.com/office/2009/07/customui">
  <ribbon>
    <tabs>
      <tab id="customTab" label="스타일" insertAfterMso="TabHome">
        <group id="groupFontTools" label="폰트 도구">
          <box id="boxFont" boxStyle="horizontal">
            <comboBox idMso="Font" showLabel="false" sizeString="WWWWWWWWWW" />
            <control idMso="FontSize" showLabel="false" />
          </box>
          <buttonGroup id="groupFont1">
          <button id="btnFont1" label="제목(일반)" tag="title01" getImage="GetButtonImage" onAction="OnFontChange" />
          <button id="btnFont2" label="제목(반전)" tag="title02" getImage="GetButtonImage" onAction="OnFontChange" />
          </buttonGroup>
          <buttonGroup id="groupFont2">
          <button id="btnFont3" label="본문(일반)" tag="text01" getImage="GetButtonImage" onAction="OnFontChange" />
          <button id="btnFont4" label="본문(반전)" tag="text02" getImage="GetButtonImage" onAction="OnFontChange" />
          </buttonGroup>
          <button id="btnFont5" label="본문(강조1)" tag="text03" getImage="GetButtonImage" onAction="OnFontChange" />
          <button id="btnFont6" label="본문(강조2)" tag="text04" getImage="GetButtonImage" onAction="OnFontChange" />
          <button id="btnFont7" label="본문(강조3)" tag="text05" getImage="GetButtonImage" onAction="OnFontChange" />
          <toggleButton id="tglParagraphSpace" imageMso="ParagraphSpaceBefore" label="문단간격" showLabel="false" onAction="OnToggleAction" getPressed="OnGetPressed"/>
          <button id="btnPgfS2" imageMso="ParagraphSpacingIncrease" tag="+0.1" onAction="OnParagraphSpace" />
          <button id="btnPgfS3" imageMso="ParagraphSpacingDecrease" tag="-0.1" onAction="OnParagraphSpace" />
        </group>
        <group id="groupFill" label="채우기색" imageMso="FillColorPicker">
          <buttonGroup id="buttongroupFill1">
            <button id="btnFillColor01" label="B1" tag="color01" getImage="GetButtonImage" onAction="OnFillColorClick" />
            <button id="btnFillColor02" label="B2" tag="color02" getImage="GetButtonImage" onAction="OnFillColorClick" />
            <button id="btnFillColor03" label="B3" tag="color03" getImage="GetButtonImage" onAction="OnFillColorClick" />
            <button id="btnFillColor04" label="B4" tag="color04" getImage="GetButtonImage" onAction="OnFillColorClick" />
          </buttonGroup>
          <buttonGroup id="buttongroupFill2">
            <button id="btnFillColor05" label="B5" tag="color05" getImage="GetButtonImage" onAction="OnFillColorClick" />
            <button id="btnFillColor06" label="C1" tag="color06" getImage="GetButtonImage" onAction="OnFillColorClick" />
            <button id="btnFillColor07" label="C2" tag="color07" getImage="GetButtonImage" onAction="OnFillColorClick" />
            <button id="btnFillColor08" label="C3" tag="color08" getImage="GetButtonImage" onAction="OnFillColorClick" />
          </buttonGroup>
          <buttonGroup id="buttongroupFill3">
            <button id="btnFillColor09" label="C4" tag="color09" getImage="GetButtonImage" onAction="OnFillColorClick" />
            <button id="btnFillColor10" label="C5" tag="color10" getImage="GetButtonImage" onAction="OnFillColorClick" />
            <button id="btnFillColor11" label="C6" tag="color11" getImage="GetButtonImage" onAction="OnFillColorClick" />
            <button id="btnFillColor12" label="C7" tag="color12" getImage="GetButtonImage" onAction="OnFillColorClick" />
          </buttonGroup>
          <button id="btnFillColor13" label="없음" showLabel="false" tag="color13" getImage="GetButtonImage" onAction="OnFillColorClick" />
        </group>
        <group id="groupLineColor" label="윤곽선색" imageMso="LineColor">
          <buttonGroup id="buttongroupLine1">
            <button id="btnLineColor01" label="B1" tag="color01" getImage="GetButtonImage" onAction="OnLineColorClick" />
            <button id="btnLineColor02" label="B2" tag="color02" getImage="GetButtonImage" onAction="OnLineColorClick" />
            <button id="btnLineColor03" label="B3" tag="color03" getImage="GetButtonImage" onAction="OnLineColorClick" />
            <button id="btnLineColor04" label="B4" tag="color04" getImage="GetButtonImage" onAction="OnLineColorClick" />
          </buttonGroup>
          <buttonGroup id="buttongroupLine2">
            <button id="btnLineColor05" label="B5" tag="color05" getImage="GetButtonImage" onAction="OnLineColorClick" />
            <button id="btnLineColor06" label="C1" tag="color06" getImage="GetButtonImage" onAction="OnLineColorClick" />
            <button id="btnLineColor07" label="C2" tag="color07" getImage="GetButtonImage" onAction="OnLineColorClick" />
            <button id="btnLineColor08" label="C3" tag="color08" getImage="GetButtonImage" onAction="OnLineColorClick" />
          </buttonGroup>
          <buttonGroup id="buttongroupLine3">
            <button id="btnLineColor09" label="C4" tag="color09" getImage="GetButtonImage" onAction="OnLineColorClick" />
            <button id="btnLineColor10" label="C5" tag="color10" getImage="GetButtonImage" onAction="OnLineColorClick" />
            <button id="btnLineColor11" label="C6" tag="color11" getImage="GetButtonImage" onAction="OnLineColorClick" />
            <button id="btnLineColor12" label="C7" tag="color12" getImage="GetButtonImage" onAction="OnLineColorClick" />
          </buttonGroup>
          <button id="btnLineColor13" label="없음" showLabel="false" tag="color13" getImage="GetButtonImage" onAction="OnLineColorClick" />
        </group>
        <group id="groupBorderEtcTools" label="도구">
          <buttonGroup id="buttongroupLineEtc">
            <gallery id="myGallery" label="색복사" image="color_copy" columns="4" rows="3" getItemCount="GetItemCount" getItemImage="GetItemImage" onAction="OnCopyHexColor" />
            <toggleButton id="tglBorderOutside" imageMso="BorderOutside" label="바깥쪽 테두리" showLabel="false" onAction="OnToggleAction" getPressed="OnGetPressed"/>
          </buttonGroup>
          <buttonGroup id="buttongroupDashStyle">
            <button id="OnLineDashStyle01" image="line_solid" label="직선" tag="1" onAction="OnLineDashStyle" />
            <button id="OnLineDashStyle11" image="line_dot" label="점선" tag="11" onAction="OnLineDashStyle" />
          </buttonGroup>
          <button id="btnOnTableBordersLRRemove" image="t_type1" label="좌우테두리제거" onAction="OnTableBordersLRRemove" />
          <button id="btnTableBorder05" image="rect_05pt" label="0.5pt" tag="0.5" onAction="OnLineWeight" />
          <button id="btnTableBorder10" image="rect_10pt" label="1.0pt" tag="1.0" onAction="OnLineWeight" />
          <button id="btnTableBorder15" image="rect_15pt" label="1.5pt" tag="1.5" onAction="OnLineWeight" />
        </group>
        <group id="groupRectTools" label="둥근사각형도구 (cm)">
          <buttonGroup id="buttongroupRec1">
            <button id="btnOnShapeTypeAdjustments00510" label=".1" image="rect_ar" tag="5,0.1,-1" onAction="OnShapeTypeAdjustments" />
            <button id="btnOnShapeTypeAdjustments00520" label=".2" image="rect_ar" tag="5,0.2,-1" onAction="OnShapeTypeAdjustments" />
            <button id="btnOnShapeTypeAdjustments00530" label=".3" image="rect_ar" tag="5,0.3,-1" onAction="OnShapeTypeAdjustments" />
          </buttonGroup>
          <buttonGroup id="buttongroupRec2">
            <button id="btnOnShapeTypeAdjustments15210" label=".1" image="rect_ur" tag="152,0.1,0" onAction="OnShapeTypeAdjustments" />
            <button id="btnOnShapeTypeAdjustments15220" label=".2" image="rect_ur" tag="152,0.2,0" onAction="OnShapeTypeAdjustments" />
            <button id="btnOnShapeTypeAdjustments15230" label=".3" image="rect_ur" tag="152,0.3,0" onAction="OnShapeTypeAdjustments" />
          </buttonGroup>
          <buttonGroup id="buttongroupRec3">
            <button id="btnOnShapeTypeAdjustments15201" label=".1" image="rect_dr" tag="152,0,0.1" onAction="OnShapeTypeAdjustments" />
            <button id="btnOnShapeTypeAdjustments15202" label=".2" image="rect_dr" tag="152,0,0.2" onAction="OnShapeTypeAdjustments" />
            <button id="btnOnShapeTypeAdjustments15203" label=".3" image="rect_dr" tag="152,0,0.3" onAction="OnShapeTypeAdjustments" />
          </buttonGroup>
        </group>
        <group id="groupSizeLocTools" label="크기/위치">
          <control idMso="ShapeHeight" showLabel="false" />
          <control idMso="ShapeWidth" showLabel="false" />
          <buttonGroup id="buttongroup1">
            <button id="btnOnShapeLocNormalize1" imageMso="SnapToGrid" tag="0.1" label=".1" onAction="OnShapeLocNormalize" />
            <button id="btnOnShapeLocNormalize2" imageMso="SnapToGrid" tag="0.2" label=".2" onAction="OnShapeLocNormalize" />
          </buttonGroup>
          <button id="btnOnhapeSizeNormalize1" imageMso="SizeToFit" tag="0.1" label="x.1" onAction="OnhapeSizeNormalize" />
          <button id="btnOnhapeSizeNormalize2" imageMso="SizeToFit" tag="0.2" label="x.2" onAction="OnhapeSizeNormalize" />
        </group>
        <group id="groupFileTools" label="저장">
          <button id="btnFile1" label="ppam" imageMso="ComAddInsDialog" onAction="ExportAsPowerPointAddIn" />
          <button id="btnFile2" label="ZIP" imageMso="FileSaveAsCurrentFileFormat" onAction="ExportAsPowerPointZip" />
        </group>
      </tab>
    </tabs>
  </ribbon>
</customUI>