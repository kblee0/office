<customUI xmlns="http://schemas.microsoft.com/office/2009/07/customui">
  <ribbon>
    <tabs>
      <tab id="customTab" label="스타일">
        <!-- 그룹1: 채우기 -->
        <group id="groupFill" label="채우기" imageMso="FillColorPicker">
            <button id="C2F2F2F" image="C2F2F2F" label="라이트 그레이"/>
            <button id="CE6B4CF" image="CE6B4CF" label="오렌지"/>
            <button id="CED1C6F" image="CED1C6F" label="크림"/>
            <button id="C959595" image="C959595" label="다크 핑크"/>
            <button id="C40B79B" image="C40B79B" label="파란색"/>
            <button id="C27AE60" image="C27AE60" label="초록색"/>
            <button id="CF39C12" image="CF39C12" label="주황색"/>
            <button id="C16A085" image="C16A085" label="다크 민트"/>
            <button id="C8E44AD" image="C8E44AD" label="라임 그린"/>
